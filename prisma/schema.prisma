generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SALES
  PROFILE_CREATOR
  SERVICE
  HR
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SALES)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs ActivityLog[] @relation("ActorLogs")
  assignedProfiles Profile[]     @relation("AssignedProfiles")
  assignedLeads    Lead[]        @relation("AssignedLeads")
  assignedMeetings Meeting[]     @relation("AssignedMeetings")
  salesTargets     SalesTarget[]
  leadRemarks      LeadRemark[]

  @@index([role])
  @@index([email])
  @@map("users")
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  actor User @relation("ActorLogs", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

enum ProfileStatus {
  UNASSIGNED
  ASSIGNED
  REASSIGNED
  ON_HOLD
  EXPIRED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Profile {
  id            String        @id @default(cuid())
  profileCode   String        @unique

  // Source
  source        String?
  sourceInfo    String?

  // Contact
  email         String?
  altEmail      String?
  phone         String
  altPhone      String?
  contactPerson String?
  creatingFor   String?

  // Basic Info
  name          String
  gender        Gender
  dob           DateTime?
  maritalStatus String?
  height        String?
  weightKg      Float?
  motherTongue  String?
  bodyType      String?
  complexion    String?
  bloodGroup    String?
  healthStatus  String?
  nativePlace   String?
  aboutYourself String?       @db.Text

  // Location
  country       String?
  state         String?
  city          String?
  citizenship   String?
  countryGrewUp String?
  visaStatus    String?

  // Religion & Horoscope
  religion      String?
  caste         String?
  subCaste      String?
  gotra         String?
  timeOfBirth   String?
  placeOfBirth  String?
  manglik       String?

  // Education & Career
  highestQualification String?
  educationField       String?
  institute            String?
  workLocation         String?
  workingWith          String?
  profession           String?
  businessName         String?
  designation          String?
  annualIncome         String?

  // Lifestyle
  diet          String?
  drinking      String?
  smoking       String?

  // Family
  fatherOccupation      String?
  motherOccupation      String?
  brothers              Int?     @default(0)
  brothersMarried       Int?     @default(0)
  sisters               Int?     @default(0)
  sistersMarried        Int?     @default(0)
  familyType            String?
  affluence             String?
  familyValues          String?
  familyBio             String?  @db.Text
  familyAnnualIncome    String?

  // Meeting
  meetings          Meeting[] @relation("MeetingProfileOne")
  meetingsAsSecond  Meeting[] @relation("MeetingProfileTwo")

  photoUrl      String?

  // Status & assignment
  status        ProfileStatus @default(UNASSIGNED)
  assignedToId  String?
  assignedTo    User?         @relation("AssignedProfiles", fields: [assignedToId], references: [id])
  assignedAt    DateTime?
  convertedFromLead Lead?

  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  partnerPreference PartnerPreference?
  subscriptions Subscription[]
  callLogs          CallLog[]
  queueEntry ProfileQueue?
  documents  ProfileDocument[]

  approvalStatus ProfileApprovalStatus @default(PENDING_APPROVAL)
  approvalNotes  String?               @db.Text

  @@index([status])
  @@index([assignedToId])
  @@index([phone])
  @@index([profileCode])
  @@map("profiles")
}

model PartnerPreference {
  id          String   @id @default(cuid())
  profileId   String   @unique
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  minAge        Int?
  maxAge        Int?
  minHeight     String?
  maxHeight     String?

  maritalStatus String?
  motherTongue  String?
  religion      String?
  caste         String?
  manglikStatus String?
  hasChildrenOk String?

  country       String?
  state         String?
  city          String?

  qualification String?
  workingWith   String?
  profession    String?
  annualIncome  String?

  diet          String?
  drinking      String?
  smoking       String?

  aboutDesiredPartner String? @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("partner_preferences")
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  PENDING
  NOT_INTERESTED
  CLOSED
}

model Lead {
  id          String     @id @default(cuid())
  name        String
  phone       String
  email       String?
  source      String?
  status      LeadStatus @default(NEW)
  notes       String?    @db.Text

  assignedToId String?
  assignedTo   User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])

  convertedProfileId String? @unique
  convertedProfile   Profile? @relation(fields: [convertedProfileId], references: [id])

  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  remarks      LeadRemark[]
  profileQueue ProfileQueue?

  @@index([status])
  @@index([assignedToId])
  @@index([phone])
  @@map("leads")
}

enum SubscriptionStatus {
  ACTIVE
  HOLD
  EXPIRED
}

model Plan {
  id            String          @id @default(cuid())
  name          String
  price         Float
  durationDays  Int
  description   String?
  active        Boolean         @default(true)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id            String             @id @default(cuid())

  profileId     String
  profile       Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)

  planId        String
  plan          Plan               @relation(fields: [planId], references: [id])

  status        SubscriptionStatus @default(ACTIVE)
  startDate     DateTime           @default(now())
  endDate       DateTime?

  createdById   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  payments      Payment[]

  @@index([status])
  @@index([profileId])
  @@map("subscriptions")
}
enum PaymentStatus {
  PAID
  PENDING
  FAILED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  PAYU
  PAYPAL
  OTHER
}

model Payment {
  id            String        @id @default(cuid())

 subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount        Float
  method        PaymentMethod @default(OTHER)
  status        PaymentStatus @default(PENDING)

  transactionId String?
  paymentLinkUrl String?
  notes         String?       @db.Text

  paidAt        DateTime?

  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  currency      String        @default("INR")

  @@index([status])
  @@index([subscriptionId])
  @@map("payments")
}

enum MeetingType {
  FACE_TO_FACE
  TELE
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  MISSED
  CANCELLED
}

model Meeting {
  id          String        @id @default(cuid())

  profileId   String
  profile     Profile       @relation("MeetingProfileOne", fields: [profileId], references: [id], onDelete: Cascade)

  profileTwoId String?
  profileTwo   Profile?     @relation("MeetingProfileTwo", fields: [profileTwoId], references: [id])

  type        MeetingType   @default(TELE)
  status      MeetingStatus @default(SCHEDULED)
  scheduledAt DateTime
  notes       String?       @db.Text

  assignedToId String?
  assignedTo   User?        @relation("AssignedMeetings", fields: [assignedToId], references: [id])

  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([profileId])
  @@map("meetings")
}

enum CallOutcome {
  CONNECTED
  NOT_ANSWERED
  BUSY
  INVALID_NUMBER
  FOLLOW_UP_NEEDED
}

model CallLog {
  id          String      @id @default(cuid())

  profileId   String
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  calledAt    DateTime    @default(now())
  outcome     CallOutcome @default(CONNECTED)
  notes       String?     @db.Text

  createdById String?
  createdAt   DateTime    @default(now())

  @@index([profileId])
  @@map("call_logs")
}

model SalesTarget {
  id            String   @id @default(cuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  month         Int
  year          Int
  targetAmount  Float

  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, month, year])
  @@map("sales_targets")
}

// ---------------------------------------------------------
// Stage 0: Role Model + Permission Matrix Foundation
// ---------------------------------------------------------
enum PermissionAction {
  VIEW
  CREATE
  EDIT
  APPROVE
  ASSIGN
  FULL
}

model Permission {
  id     String           @id @default(cuid())
  module String
  action PermissionAction

  roles  RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

enum LeadCallOutcome {
  INTERESTED
  FOLLOW_UP
  NOT_INTERESTED
  DNP
}

model LeadRemark {
  id        String          @id @default(cuid())
  leadId    String
  lead      Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User            @relation(fields: [actorId], references: [id])
  outcome   LeadCallOutcome
  remark    String?         @db.Text
  createdAt DateTime        @default(now())

  @@index([leadId])
  @@map("lead_remarks")
}

enum ProfileQueueStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model ProfileQueue {
  id              String             @id @default(cuid())
  leadId          String             @unique
  lead            Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status          ProfileQueueStatus @default(PENDING)
  createdProfileId String?           @unique
  createdProfile  Profile?           @relation(fields: [createdProfileId], references: [id])
  sentToQueueAt   DateTime           @default(now())
  sentById        String?

  @@index([status])
  @@map("profile_queue")
}

enum DocumentType {
  PHOTO
  ID_PROOF
  OTHER
}

model ProfileDocument {
  id         String       @id @default(cuid())
  profileId  String
  profile    Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  url        String
  type       DocumentType
  uploadedAt DateTime     @default(now())

  @@index([profileId])
  @@map("profile_documents")
}

enum ProfileApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  NEEDS_CHANGES
}